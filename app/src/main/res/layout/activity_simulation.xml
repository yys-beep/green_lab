<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF3E0">

    <TextView
        android:id="@+id/tv_sim_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sunlight Experiment"
        android:textSize="32sp"
        android:textColor="#E65100"
        android:fontFamily="@font/fredoka"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/iv_dynamic_sun"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_sun"
        android:alpha="0.5"
        app:layout_constraintTop_toTopOf="@id/iv_sim_plant"
        app:layout_constraintBottom_toBottomOf="@id/iv_sim_plant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.8"
        app:layout_constraintVertical_bias="0.2" />

    <ImageView
        android:id="@+id/iv_sim_plant"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:src="@drawable/ic_plant_small"
        app:layout_constraintTop_toBottomOf="@id/tv_sim_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tv_sim_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Too little sunlight!"
        android:textSize="22sp"
        android:textColor="#D84315"
        android:fontFamily="@font/fredoka"
        android:background="@drawable/bg_rounded_white"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toBottomOf="@id/iv_sim_plant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp"/>

    <LinearLayout
        android:id="@+id/ll_slider_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_sim_feedback"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dark"
            android:textSize="18sp"
            android:fontFamily="@font/fredoka"/>

        <SeekBar
            android:id="@+id/seekbar_sun"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="10"
            android:layout_marginHorizontal="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bright"
            android:textSize="18sp"
            android:fontFamily="@font/fredoka"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_dashboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/ll_slider_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="🌡️ Heat:"
                    android:fontFamily="@font/fredoka"
                    android:textSize="16sp"/>
                <ProgressBar
                    android:id="@+id/pb_heat"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="15dp"
                    android:max="100"
                    android:progress="10"
                    android:progressTint="#E53935"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">
                <TextView
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:text="💧 Water:"
                    android:fontFamily="@font/fredoka"
                    android:textSize="16sp"/>
                <ProgressBar
                    android:id="@+id/pb_water"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="15dp"
                    android:max="100"
                    android:progress="90"
                    android:progressTint="#1E88E5"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tv_theory_explanation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Plants need sunlight for power, but too much heat makes them lose water!"
        android:textSize="16sp"
        android:textColor="#5D4037"
        android:fontFamily="@font/fredoka"
        android:textAlignment="center"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/card_dashboard" />

    <ImageView
        android:id="@+id/iv_mascot_quiz"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_mascot_idle"
        app:layout_constraintBottom_toTopOf="@id/btn_to_quiz"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="-10dp"
        android:elevation="5dp"/>

    <Button
        android:id="@+id/btn_to_quiz"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Take Quiz!"
        android:textSize="22sp"
        android:fontFamily="@font/fredoka"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="30dp" />

</androidx.constraintlayout.widget.ConstraintLayout>