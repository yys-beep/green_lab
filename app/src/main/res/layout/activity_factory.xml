<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF9C4">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_factory_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Drag ingredients to make food!"
        android:textSize="24sp"
        android:textAlignment="center"
        android:textColor="#F57F17"
        android:fontFamily="@font/fredoka"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- The Leaf Factory -->

    <!-- Hidden Output: Sugar -->

    <!-- Hidden Output: Oxygen -->

    <!-- Dynamic Feedback Panel -->

    <ImageView
        android:id="@+id/iv_leaf_factory"
        android:layout_width="355dp"
        android:layout_height="311dp"
        android:layout_marginTop="4dp"
        android:src="@drawable/ic_leaf_factory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_factory_title" />

    <ImageView
        android:id="@+id/iv_glucose_output"
        android:layout_width="83dp"
        android:layout_height="85dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_glucose"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="@+id/iv_leaf_factory"
        app:layout_constraintTop_toBottomOf="@+id/tv_factory_title" />

    <ImageView
        android:id="@+id/iv_oxygen_output"
        android:layout_width="86dp"
        android:layout_height="83dp"
        android:src="@drawable/ic_oxygen"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="@+id/iv_leaf_factory"
        app:layout_constraintEnd_toEndOf="@+id/iv_leaf_factory" />

    <TextView
        android:id="@+id/tv_factory_feedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_rounded_white"
        android:fontFamily="@font/fredoka"
        android:padding="12dp"
        android:text="Waiting for ingredients..."
        android:textAlignment="center"
        android:textColor="#2E7D32"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iv_leaf_factory" />

    <!-- NEW: Educational Description to fill the empty space! -->
    <TextView
        android:id="@+id/tv_educational_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/fredoka"
        android:text="Plants are like magical chefs! They need 3 special ingredients to cook their food. Can you help the leaf collect them?"
        android:textAlignment="center"
        android:textColor="#5D4037"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_factory_feedback" />

    <!-- CENTERED: Explore Plant Button -->
    <Button
        android:id="@+id/btn_next_explore"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="Explore Plant!"
        android:textSize="22sp"
        android:fontFamily="@font/fredoka"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_educational_desc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="15dp" />

    <!-- BUG FIX: Mascot anchored strictly to the bottom -->
    <ImageView
        android:id="@+id/iv_mascot"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_mascot_idle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="20dp"/>

    <!-- BUG FIX: Draggables anchored strictly to the bottom -->
    <LinearLayout
        android:id="@+id/ll_draggables"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_mascot"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="25dp"
        android:layout_marginEnd="16dp">

        <ImageView
            android:id="@+id/drag_sun"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginHorizontal="8dp"
            android:src="@drawable/ic_sun" />

        <ImageView
            android:id="@+id/drag_water"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginHorizontal="8dp"
            android:src="@drawable/ic_water" />

        <ImageView
            android:id="@+id/drag_co2"
            android:layout_width="75dp"
            android:layout_height="75dp"
            android:layout_marginHorizontal="8dp"
            android:src="@drawable/ic_cloud" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>