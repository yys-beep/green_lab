<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F7FA">

    <TextView
        android:id="@+id/tv_explore_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/fredoka"
        android:text="Plant Scavenger Hunt!"
        android:textColor="#00838F"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Find and tap all 4 plant parts to unlock the Lab!"
        android:textColor="#006064"
        android:textSize="16sp"
        android:fontFamily="@font/fredoka"
        app:layout_constraintTop_toBottomOf="@id/tv_explore_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <ImageView
        android:id="@+id/iv_plant_diagram"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_plant_diagram"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_explore_title"
        app:layout_constraintBottom_toTopOf="@id/card_knowledge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.45" />

    <Button
        android:id="@+id/hotspot_flower"
        android:layout_width="39dp"
        android:layout_height="38dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@id/iv_plant_diagram"
        app:layout_constraintEnd_toEndOf="@id/iv_plant_diagram"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="@id/iv_plant_diagram"
        app:layout_constraintTop_toTopOf="@id/iv_plant_diagram"
        app:layout_constraintVertical_bias="0.085" />

    <ImageView
        android:id="@+id/iv_flower_graphic"
        android:layout_width="42dp"
        android:layout_height="37dp"
        android:src="@drawable/ic_flower"
        app:layout_constraintBottom_toBottomOf="@id/iv_plant_diagram"
        app:layout_constraintEnd_toEndOf="@id/iv_plant_diagram"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="@id/iv_plant_diagram"
        app:layout_constraintTop_toTopOf="@id/iv_plant_diagram"
        app:layout_constraintVertical_bias="0.085" />

    <Button
        android:id="@+id/hotspot_leaf"
        android:layout_width="47dp"
        android:layout_height="47dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@id/iv_plant_diagram"
        app:layout_constraintEnd_toEndOf="@id/iv_plant_diagram"
        app:layout_constraintHorizontal_bias="0.381"
        app:layout_constraintStart_toStartOf="@id/iv_plant_diagram"
        app:layout_constraintTop_toTopOf="@id/iv_plant_diagram"
        app:layout_constraintVertical_bias="0.432" />

    <Button
        android:id="@+id/hotspot_stem"
        android:layout_width="19dp"
        android:layout_height="164dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@id/iv_plant_diagram"
        app:layout_constraintEnd_toEndOf="@id/iv_plant_diagram"
        app:layout_constraintStart_toStartOf="@id/iv_plant_diagram"
        app:layout_constraintTop_toTopOf="@id/iv_plant_diagram"
        app:layout_constraintVertical_bias="0.381" />

    <Button
        android:id="@+id/hotspot_roots"
        android:layout_width="104dp"
        android:layout_height="90dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@id/iv_plant_diagram"
        app:layout_constraintEnd_toEndOf="@id/iv_plant_diagram"
        app:layout_constraintStart_toStartOf="@id/iv_plant_diagram" />


    <androidx.cardview.widget.CardView
        android:id="@+id/card_knowledge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/ll_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_info_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Plant Explorer"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:fontFamily="@font/fredoka"/>

            <TextView
                android:id="@+id/tv_info_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Tap a part of the plant to learn what it does!"
                android:textSize="18sp"
                android:textAlignment="center"
                android:textColor="#333333"
                android:fontFamily="@font/fredoka"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/ll_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_go_simulation">

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Parts Found: 0 / 4"
            android:textSize="18sp"
            android:textColor="#00838F"
            android:textStyle="bold"
            android:fontFamily="@font/fredoka"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/pb_explore"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="4"
            android:progress="0"
            android:progressTint="#4CAF50"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_go_simulation"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="Go to Lab"
        android:textSize="20sp"
        android:paddingHorizontal="40dp"
        android:layout_marginBottom="24dp"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>