<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3E5F5">

    <!-- Top Progress Tracker -->
    <TextView
        android:id="@+id/tv_quiz_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Question 1 of 5"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#8E24AA"
        android:fontFamily="@font/fredoka"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/pb_quiz_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="15dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="8dp"
        android:max="5"
        android:progress="1"
        android:progressTint="#AB47BC"
        app:layout_constraintTop_toBottomOf="@id/tv_quiz_progress" />

    <!-- The Thinking Mascot -->
    <ImageView
        android:id="@+id/iv_quiz_mascot"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/ic_quiz_thinking"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/pb_quiz_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- The Quiz Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/iv_quiz_mascot">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What gas do plants absorb?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:fontFamily="@font/fredoka"
                android:textAlignment="center"
                android:layout_marginBottom="20dp"/>

            <RadioGroup
                android:id="@+id/rg_answers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/rb_ans1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 1"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_rounded_white"
                    android:elevation="2dp"/>

                <RadioButton
                    android:id="@+id/rb_ans2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 2"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka"
                    android:padding="10dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_rounded_white"
                    android:elevation="2dp"/>

                <RadioButton
                    android:id="@+id/rb_ans3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 3"
                    android:textSize="18sp"
                    android:fontFamily="@font/fredoka"
                    android:padding="10dp"
                    android:background="@drawable/bg_rounded_white"
                    android:elevation="2dp"/>
            </RadioGroup>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btn_submit_quiz"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="30dp"
        android:text="Submit Answer"
        android:textSize="22sp"
        android:fontFamily="@font/fredoka"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>